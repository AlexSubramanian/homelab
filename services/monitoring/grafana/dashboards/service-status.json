    {
      "id": 30, "title": "Network Throughput", "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(node_network_receive_bytes_total{hostname=\"arr-stack\",device=~\"ens.*|eth.*\"}[5m]))", "legendFormat": "arr-stack in", "refId": "A" },
